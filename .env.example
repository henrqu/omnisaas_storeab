# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Required for OpenAI real-time Copilot processing.
# Configure this in the Secrets panel in the AI Studio UI to activate real-time intelligence.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL=

# SUPABASE_ANON_KEY: The anonymous / public API key of your Supabase project.
SUPABASE_ANON_KEY=

# STRIPE_SECRET_KEY: Your Stripe API Secret Key (keep server-side, never expose to front-end)
STRIPE_SECRET_KEY=

# STRIPE_PRICE_USD: Stripe Price ID for USD 19.99 (English)
STRIPE_PRICE_USD=

# STRIPE_PRICE_EUR: Stripe Price ID for EUR 19.99 (Spanish)
STRIPE_PRICE_EUR=

# STRIPE_PRICE_BRL: Stripe Price ID for BRL 97.90 (Portuguese)
STRIPE_PRICE_BRL=
